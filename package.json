{
  "name": "pandaslab",
  "private": false,
  "version": "1.0.0",
  "description": "Interactive Pandas Data Analysis Training Platform",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "version": "node scripts/version.js",
    "release": "node scripts/version.js patch && git add package.json CHANGELOG.md && git commit -m \"chore(release): bump version\" && git tag v$(node -p \"require('./package.json').version\")",
    "lint": "vue-tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wryzxc/pandans.git"
  },
  "bugs": {
    "url": "https://github.com/wryzxc/pandans/issues"
  },
  "homepage": "https://wryzxc.github.io/pandans",
  "dependencies": {
    "@codemirror/basic-setup": "^0.20.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@monaco-editor/loader": "^1.7.0",
    "codemirror": "^6.0.2",
    "echarts": "^6.0.0",
    "monaco-editor": "^0.55.1",
    "pyodide": "^0.29.3",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
